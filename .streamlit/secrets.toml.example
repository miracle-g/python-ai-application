# Streamlit Community Cloud の Secrets に貼り付ける見本。
# 実際の値は share.streamlit.io のアプリ設定 → "Secrets" に入力する
# （このファイルはあくまで見本。実キー・実パスワードは書かないこと）。
#
# ローカルで試すなら .streamlit/secrets.toml にコピーして値を埋める。
# .streamlit/secrets.toml は .gitignore 済みなのでコミットされない。

# Gemini API キー（.env の GEMINI_API_KEY と同じもの）
GEMINI_API_KEY = "AIza..."

# 公開アプリのログインパスワード。
# これを設定すると、URLを知る第三者が勝手に使う（＝APIキーを消費する）のを防げる。
app_password = "ここに任意のパスワード"
